# --- Plaid (use Sandbox for development) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Sandbox bank item the live loop watches - created by `npm run plaid:sandbox`.
PLAID_ACCESS_TOKEN=
# Wallet the live loop advances to (the demo borrower from `npm run demo`).
DEMO_BORROWER_PUBLIC_KEY=
# Demo lever: stage an extra pre-payday bill (USD) to force a shortfall. Empty = honest data.
DEMO_EXTRA_OUTFLOW_USD=

# --- Casper ---
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK=casper-test
# Path to the agent's secret key (the wallet that signs advance/repay txns).
# In production this is provisioned via CSPR.click; for the agent backend use a keypair.
AGENT_SECRET_KEY_PATH=./keys/agent_secret_key.pem
# Deployed QuidPool contract hash (hash-...)
QUID_CONTRACT_HASH=
# CEP-18 stablecoin the pool lends in (hash-...). Used to seed via approve + fund_pool.
QUID_STABLECOIN_ADDRESS=
# `reputation` dictionary seed URef from the deployed contract's named keys (cspr.live).
QUID_REPUTATION_DICT_UREF=

# --- x402 (paid verification calls) ---
X402_FACILITATOR_URL=
# Endpoint the agent pays to verify income / pull a risk signal.
VERIFY_ENDPOINT_URL=

# --- Stripe (subscription tiers) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs per tier (create the products in Stripe, then paste their price_… ids).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=

# --- Consumer-app backend (agent/src/server.ts) ---
SERVER_PORT=8787
WEB_ORIGIN=http://localhost:5173

# --- Off-ramp / cash-out (Casper advance -> user's bank) ---
# No turnkey Casper->fiat provider exists; unset = simulated ACH payout (demo).
# Set to a provider (coinflow|stripe|dwolla) once the real payout integration lands.
OFFRAMP_PROVIDER=

# --- Agent rules (off-chain config; in prod these are per-user) ---
SHORTFALL_THRESHOLD_USD=0
POLL_INTERVAL_SECONDS=60
