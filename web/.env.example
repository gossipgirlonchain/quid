# Backend base URL (default: /api, proxied to the agent server on :8787 in dev).
VITE_API_BASE=/api

# CSPR.click app id (from console.cspr.build). Unset = demo login (no real wallet).
VITE_CSPRCLICK_APP_ID=

# Casper fiat on-ramp (Ramp Network, a Casper partner — rampnetwork.com dashboard).
# Unset = the "Add funds" flow opens Ramp's demo widget instead of the live one.
VITE_RAMP_HOST_API_KEY=
# Ramp asset code for Casper (NETWORK_TOKEN form). Confirm on Ramp's supported-assets list.
VITE_RAMP_ASSET=CSPR_CSPR
